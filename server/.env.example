DATABASE_URL="postgresql://usuario:password@localhost:5432/esbrillante"
JWT_SECRET="cambia-esto-por-una-clave-larga-y-segura"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Key compartida para autenticar el endpoint MCP (/mcp) usado por Claude Code
# desde otros repos. Generar con: openssl rand -hex 32
MCP_API_KEY="cambia-esto-por-una-clave-larga-y-segura"

# Subida de archivos de clientes a Google Drive vía Service Account.
# GOOGLE_SERVICE_ACCOUNT_KEY: contenido completo del JSON de la cuenta de
# servicio (como string de una sola línea, ej. usando `jq -c . key.json`).
# DRIVE_RESPUESTAS_ROOT_ID: ID de la carpeta de Drive compartida con el
# email de la cuenta de servicio (rol Editor) — está en la URL de la carpeta.
# Si no se configuran, la subida de archivos queda deshabilitada pero el
# resto del sistema sigue funcionando normal.
GOOGLE_SERVICE_ACCOUNT_KEY=''
DRIVE_RESPUESTAS_ROOT_ID=''
